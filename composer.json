{
    "name": "jansuchanek/noauth",
    "description": "Multi-provider OAuth login for Nette Framework — Google, Microsoft, Facebook",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "league/oauth2-google": "^4.0",
        "league/oauth2-facebook": "^2.0",
        "league/oauth2-client": "^2.0"
    },
    "require-dev": {
        "nette/tester": "^2.6",
        "nette/di": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "NOAuth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NOAuth\\Tests\\": "tests/"
        }
    }
}
